# Hotkey configuration
HOTKEY_KEY=space
HOTKEY_MODS=alt

# Timeouts
BROWSER_TIMEOUT=30

# Groq API (get a free key at console.groq.com)
GROQ_API_KEY=

# Anthropic (Claude fallback for complex browser research — optional)
ANTHROPIC_API_KEY=

# Music app for media playback (default: "Music" = Apple Music)
# Change to "Spotify", "Tidal", etc. — must match the app name in /Applications
MUSIC_APP=Music
